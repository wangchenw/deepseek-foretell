# MiniMax 模型（OpenAI 兼容接口）
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Tavily 互联网搜索
TAVILY_API_KEY=your-tavily-api-key

# LangSmith 可观测性（可选）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=foretell

# 部署环境：dev | prod
DEPLOY_ENV=dev

# 自托管持久化（prod 必填）
DATABASE_URL=postgresql://user:pass@localhost:5432/foretell

# 疯狂体育数据源：mock（测试/离线）| mysql（data_center）
CRAZY_SPORTS_DATA_SOURCE=mock

# 疯狂体育 MySQL（CRAZY_SPORTS_DATA_SOURCE=mysql 时必填）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=data_center

# 疯狂体育 HTTP API（可选，未来接入）
CRAZY_SPORTS_API_BASE=
CRAZY_SPORTS_API_KEY=

# API 服务
API_HOST=127.0.0.1
API_PORT=8000

# JWT 密钥（dev 默认即可）
JWT_SECRET=dev-jwt-secret-change-me
